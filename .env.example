# API Keys (use secure values in production)
SNYK_API_KEY=your_snyk_api_key_here
OWASP_ZAP_URL=http://localhost:8080

# Application Settings
VITE_APP_NAME=InkAI Studio
VITE_APP_VERSION=1.0.0
VITE_API_BASE_URL=https://api.inkaistudio.com

# Security Settings
VITE_CSRF_TOKEN_NAME=csrf-token
VITE_SESSION_TIMEOUT=3600000

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_ERROR_REPORTING=false

# Development Settings
VITE_DEBUG_MODE=false
VITE_MOCK_API=false